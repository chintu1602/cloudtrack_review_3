# Azure Infrastructure Configuration Variables

# Name of the resource group to contain all resources
resource_group_name     = "your-resource-group-name"

# Azure region where resources will be deployed (e.g., East US, West US, etc.)
location                = "East US"

# CIDR block for the virtual network
vnet_cidr               = "10.0.0.0/16"

# PostgreSQL Flexible Server Credentials
postgres_admin_user     = "your_postgres_admin_user"
postgres_admin_password = "your_secure_postgres_password_123!"

# Build VM settings
vm_size                 = "Standard_D2s_v3"
vm_admin_password       = "your_secure_vm_password_123!"

# Azure Key Vault (Must be globally unique)
keyvault_name           = "your-unique-keyvault-name"

# Whether the Key Vault is publicly accessible (keep true for initial apply to write secrets, then false to lock it down)
keyvault_public_network_access_enabled = true

# Azure Container Registry (Must be globally unique, lowercase alphanumeric only)
acr_name                = "youruniqueacrname"

# AKS Cluster Name
aks_cluster_name        = "your-aks-cluster-name"

# SMTP Configuration (e.g., for sending meal reminders via Gmail App Passwords)
smtp_username           = "your_smtp_email@example.com"
smtp_password           = "your_smtp_app_password"

# Azure OpenAI / AI Foundry Model Settings (dynamic deployment)
# Configure these based on model availability in your Azure region
openai_model_name       = "gpt-4"
openai_api_version      = "2024-02-01"

