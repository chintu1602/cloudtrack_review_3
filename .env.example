# ============================================================
# NutriAI Health Portal - Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql://nutriai_user:nutriai_password@localhost:5432/nutriai

# JWT Authentication
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=nutriai-documents

# Azure Service Bus
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_TOPIC_NAME=meal-reminders
AZURE_SERVICE_BUS_SUBSCRIPTION_NAME=email-sender

# Azure Function App (OCR)
FUNCTION_APP_URL=
FUNCTION_APP_KEY=

# Microsoft Entra ID (SSO)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Email (SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@nutriai-health.com

# SendGrid (alternative)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nutriai-health.com

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# App URL (for email links)
APP_URL=http://localhost:3000
